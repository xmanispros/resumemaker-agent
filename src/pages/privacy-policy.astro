---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Privacy Policy | ResumeMaker Agent';
const description = 'How ResumeMaker Agent handles your data. Your resume content stays on your device — we do not require login or store your resume on a server.';
const base = import.meta.env.BASE_URL;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://xmanispros.github.io/resumemaker-agent" },
    { "@type": "ListItem", "position": 2, "name": "Privacy Policy", "item": "https://xmanispros.github.io/resumemaker-agent/privacy-policy" }
  ]
};
---
<BaseLayout title={title} description={description} canonicalPath="/privacy-policy">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16" style="background: var(--neu-bg);">
    <div class="neu-badge inline-block mb-4">
      <p class="eyebrow">Legal</p>
    </div>
    <h1 class="text-4xl font-semibold" style="color: var(--neu-text);">Privacy Policy</h1>
    <p class="mt-2 text-sm" style="color: var(--neu-text-dim);">Last updated: June 2026</p>

    <div class="neu-card mt-8 space-y-6 p-6 sm:p-8">
      <div>
        <h2 class="text-lg font-semibold" style="color: var(--neu-text);">What we collect</h2>
        <p class="mt-2 text-sm" style="color: var(--neu-text-dim);">
          ResumeMaker Agent does not require an account or login. The details you enter in the builder
          (name, photo, contact information, work history, etc.) are stored locally in your browser's
          storage so you can resume editing later — we don't transmit this content to our servers to
          generate your resume.
        </p>
      </div>
      <div class="neu-divider"></div>
      <div>
        <h2 class="text-lg font-semibold" style="color: var(--neu-text);">Advertising</h2>
        <p class="mt-2 text-sm" style="color: var(--neu-text-dim);">
          We show a single Google AdSense unit on the Download page before your PDF is generated. Google
          may use cookies to serve relevant ads; you can review Google's own privacy practices for
          details on how that data is handled.
        </p>
      </div>
      <div class="neu-divider"></div>
      <div>
        <h2 class="text-lg font-semibold" style="color: var(--neu-text);">Analytics</h2>
        <p class="mt-2 text-sm" style="color: var(--neu-text-dim);">
          We may use basic, anonymized analytics to understand which pages are useful and which aren't —
          this never includes the content of your resume.
        </p>
      </div>
      <div class="neu-divider"></div>
      <div>
        <h2 class="text-lg font-semibold" style="color: var(--neu-text);">Your control</h2>
        <p class="mt-2 text-sm" style="color: var(--neu-text-dim);">
          Because your resume data lives in your browser, clearing your browser's site data for
          ResumeMaker Agent removes it completely. We have no separate copy to delete.
        </p>
      </div>
      <div class="neu-divider"></div>
      <div>
        <h2 class="text-lg font-semibold" style="color: var(--neu-text);">Contact</h2>
        <p class="mt-2 text-sm" style="color: var(--neu-text-dim);">
          Questions about this policy? Visit our <a href={base + 'contact'} class="text-teal hover:underline">Contact Us</a> page.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
