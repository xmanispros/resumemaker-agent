---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'About Us — ResumeMaker Agent | Free Resume Builder';
const description = 'Learn about ResumeMaker Agent — a free online resume maker with AI-guided builder, 90+ templates, and free PDF download. No payment, no login.';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://resumemakeragent.com" },
    { "@type": "ListItem", "position": 2, "name": "About", "item": "https://resumemakeragent.com/about" }
  ]
};

const aboutSchema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About ResumeMaker Agent",
  "url": "https://resumemakeragent.com/about",
  "mainEntity": {
    "@type": "Organization",
    "name": "ResumeMaker Agent",
    "url": "https://resumemakeragent.com",
    "description": "ResumeMaker Agent is a free online resume maker that helps job seekers create professional resumes without payment."
  }
};
---
<BaseLayout title={title} description={description} canonicalPath="/about">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(aboutSchema)} />

  <section class="mx-auto max-w-3xl px-4 py-12 sm:px-6 sm:py-16" style="background: var(--neu-bg);">
    <div class="neu-badge inline-block mb-4">
      <p class="eyebrow">About</p>
    </div>
    <h1 class="text-4xl font-semibold" style="color: var(--neu-text);">About ResumeMaker Agent</h1>
    <p class="mt-3 max-w-xl" style="color: var(--neu-text-dim);">
      We believe everyone deserves a professional resume without paying for it.
    </p>

    <div class="mt-10 space-y-8">
      <div class="neu-card p-5 sm:p-6">
        <h2 class="text-lg font-semibold" style="color: var(--neu-text);">Our Mission</h2>
        <p class="mt-3 text-sm" style="color: var(--neu-text-dim);">
          ResumeMaker Agent was built to solve a simple problem: too many resume builders promise "free" but hide paywalls behind every feature. We created a tool that is genuinely free — no trial that turns into a bill, no card required to download, no dark patterns.
        </p>
      </div>

      <div class="neu-card p-5 sm:p-6">
        <h2 class="text-lg font-semibold" style="color: var(--neu-text);">How It Works</h2>
        <p class="mt-3 text-sm" style="color: var(--neu-text-dim);">
          Our AI-guided agent walks you through building your resume step by step. It asks for the essential details first — name, contact, and photo — then offers optional sections like summary, skills, education, experience, and projects. You can preview your resume in real time across 90+ templates and download it as a PDF or Word document without creating an account.
        </p>
      </div>

      <div class="neu-card p-5 sm:p-6">
        <h2 class="text-lg font-semibold" style="color: var(--neu-text);">Privacy First</h2>
        <p class="mt-3 text-sm" style="color: var(--neu-text-dim);">
          Your resume data never leaves your device. Everything is stored in your browser's local storage. We don't collect, store, or transmit your personal information. When you close the browser, your data stays on your device — not on our servers.
        </p>
      </div>

      <div class="neu-card p-5 sm:p-6">
        <h2 class="text-lg font-semibold" style="color: var(--neu-text);">Built for Everyone</h2>
        <p class="mt-3 text-sm" style="color: var(--neu-text-dim);">
          Whether you're a fresh graduate in India, a professional switching careers, or someone re-entering the workforce — ResumeMaker Agent is designed to work for you. We support multiple template styles (Modern, Professional, Creative, Simple, ATS-Friendly), mobile-friendly editing, and free PDF downloads.
        </p>
      </div>

      <div class="neu-cta mt-8 text-center">
        <h2 class="text-xl font-semibold" style="color: var(--neu-text);">Ready to build your resume?</h2>
        <p class="mt-2 text-sm" style="color: var(--neu-text-dim);">Start for free — no login, no payment, no surprises.</p>
        <a href="/builder" class="neu-btn-primary mt-5 inline-flex">Create Resume — It's Free</a>
      </div>
    </div>
  </section>
</BaseLayout>
