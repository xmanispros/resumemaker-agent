        .rsm-item-sub { font-size: 14px; color: #5B6B8C; }
        .rsm-skills { display: flex; flex-wrap: wrap; gap: 7px; align-items: center; justify-content: flex-start; }
        .rsm-pill { font-size: 12px; padding: 5px 14px; border: 1.5px solid; border-radius: 999px; font-weight: 500; line-height: 1.3; text-align: center; display: inline-flex; align-items: center; justify-content: center; min-width: 40px; }
        .rsm-links { display: flex; flex-direction: column; gap: 6px; }
        .rsm-link { font-size: 13px; color: #2A3654; word-break: break-all; }
        .rsm-sidebar .rsm-photo-fallback { background: rgba(255,255,255,0.2) !important; }
        .rsm-sidebar .rsm-name-sidebar { font-size: 22px; color: white; margin-top: 14px; font-weight: 700; }
        .rsm-sidebar .rsm-contact-sidebar { color: rgba(255,255,255,0.85); font-size: 12.5px; margin-top: 4px; }
        .rsm-sidebar .rsm-section { margin-bottom: 16px; }
        .rsm-sidebar .rsm-section-title { color: rgba(255,255,255,0.7); border-bottom-color: rgba(255,255,255,0.25); font-size: 12px; }
