    function buildPDFWrapper(){
      var A4_W=794, A4_H=1123;
      var wrapper=document.createElement('div');
      wrapper.style.cssText='position:absolute;left:-9999px;top:0;width:'+A4_W+'px;height:'+A4_H+'px;background:#ffffff;overflow:hidden;margin:0;padding:0;font-family:Inter,Segoe UI,system-ui,-apple-system,sans-serif;';
      var allStyles=document.createElement('style');
      allStyles.textContent=getResumeCSS(A4_W,A4_H);
      wrapper.appendChild(allStyles);
      var previewEl=document.getElementById('resume-preview');
      var resumeClone=previewEl.cloneNode(true);
      resumeClone.style.cssText='width:'+A4_W+'px;height:'+A4_H+'px;box-sizing:border-box;overflow:hidden;background:#ffffff;';
      wrapper.appendChild(resumeClone);
      return wrapper;
    }

    /* ══════════════════════════════════════════════════════
       PDF METHOD 1: html2canvas + jsPDF (primary)
       ══════════════════════════════════════════════════════ */
    function pdfMethod_html2canvas(){
      return new Promise(function(resolve, reject){
        if(typeof html2canvas==='undefined'||typeof jspdf==='undefined'){
          reject(new Error('LIBS_NOT_LOADED'));
          return;
        }
        var wrapper=buildPDFWrapper();
        document.body.appendChild(wrapper);
        document.fonts.ready.then(function(){
          setTimeout(function(){
            html2canvas(wrapper,{
              scale:2, useCORS:true, allowTaint:true, backgroundColor:'#ffffff',
              logging:false, width:794, height:1123, windowWidth:794, windowHeight:1123,
              imageTimeout:15000, removeContainer:true
            }).then(function(canvas){
              document.body.removeChild(wrapper);
              var imgData=canvas.toDataURL('image/jpeg',0.98);
              var pdf=new jspdf.jsPDF({unit:'mm',format:'a4',orientation:'portrait'});
              var pw=pdf.internal.pageSize.getWidth();
              var ph=pdf.internal.pageSize.getHeight();
              pdf.addImage(imgData,'JPEG',0,0,pw,ph,'','MEDIUM');
              var blob=pdf.output('blob');
              resolve({blob:blob, dataUrl:pdf.output('dataurlstring')});
            }).catch(function(err){
              if(wrapper.parentNode)document.body.removeChild(wrapper);
              reject(err);
            });
          },150);
        });
      });
    }

    /* ══════════════════════════════════════════════════════
       PDF METHOD 2: Browser print-to-PDF (fallback)
       ══════════════════════════════════════════════════════ */
    function pdfMethod_browserPrint(){
      return new Promise(function(resolve, reject){
        try {
          var A4_W=794, A4_H=1123;
          var printWin=window.open('','_blank','width='+A4_W+',height='+A4_H);
          if(!printWin){reject(new Error('POPUP_BLOCKED'));return;}
          var previewEl=document.getElementById('resume-preview');
          var resumeHtml=previewEl.innerHTML;
          var css=getResumeCSS(A4_W,A4_H);
          printWin.document.write('<!DOCTYPE html><html><head><meta charset="utf-8"><title>Resume PDF</title>'
            +'<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>'
            +'<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">'
            +'<style>'+css+'</style></head><body>'
            +'<div class="rsm-doc rsm-single font-sans">'+resumeHtml+'</div>'
            +'</body></html>');
          printWin.document.close();
          setTimeout(function(){
            try {
              printWin.focus();
              printWin.print();
              resolve({dataUrl:null, blob:null, usedPrint:true});
            } catch(e) {
              reject(new Error('PRINT_FAILED'));
            }
          },1000);
        } catch(e) {
          reject(e);
        }
      });
    }

    /* ══════════════════════════════════════════════════════
       PDF METHOD 3: html2canvas only → JPEG blob download
       ══════════════════════════════════════════════════════ */
    function pdfMethod_canvasJpeg(){
      return new Promise(function(resolve, reject){
        if(typeof html2canvas==='undefined'){
          reject(new Error('html2canvas not loaded'));
          return;
        }
        var wrapper=buildPDFWrapper();
        document.body.appendChild(wrapper);
        document.fonts.ready.then(function(){
          setTimeout(function(){
            html2canvas(wrapper,{
              scale:2, useCORS:true, allowTaint:true, backgroundColor:'#ffffff',
              logging:false, width:794, height:1123, windowWidth:794, windowHeight:1123,
              imageTimeout:15000
            }).then(function(canvas){
              document.body.removeChild(wrapper);
              canvas.toBlob(function(blob){
                resolve({blob:blob, dataUrl:null, filename:getFileName()+'_resume.jpg'});
              },'image/jpeg',0.95);
            }).catch(function(err){
              if(wrapper.parentNode)document.body.removeChild(wrapper);
              reject(err);
            });
          },150);
        });
      });
    }

    /* ══════════════════════════════════════════════════════
       PDF METHOD 4: SVG foreignObject inline → download HTML
       ══════════════════════════════════════════════════════ */
    function pdfMethod_htmlFallback(){
      return new Promise(function(resolve){
        var previewEl=document.getElementById('resume-preview');
        var css=getResumeCSS(794,1123);
        var htmlContent='<!DOCTYPE html><html><head><meta charset="utf-8"><title>'+getFileName()+'</title>'
          +'<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>'
          +'<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">'
          +'<style>'+css+'</style></head><body style="display:flex;justify-content:center;align-items:center;min-height:100vh;background:#f5f5f5;">'
          +'<div style="width:794px;height:1123px;background:#fff;box-shadow:0 2px 12px rgba(0,0,0,0.1);">'
          +previewEl.innerHTML+'</div></body></html>';
        var blob=new Blob([htmlContent],{type:'text/html'});
        resolve({blob:blob, dataUrl:null, filename:getFileName()+'_resume.html', isHtml:true});
      });
    }

    /* ══════════════════════════════════════════════════════
       DOCX FALLBACK: HTML file that Word can open
       ══════════════════════════════════════════════════════ */
    function buildDocxHtmlFallback(d,t){
      var ac=t.accent;
      var name=esc(d.fullName)||'Resume';
      var contact=[];
      if(d.contactValue)contact.push(esc(d.contactValue));
      if(d.location)contact.push(esc(d.location));
      var contactStr=contact.join(' &bull; ');

      var html='<!DOCTYPE html><html><head><meta charset="utf-8"><title>'+name+' - Resume</title>'
        +'<style>'
        +'body{font-family:Arial,Helvetica,sans-serif;color:#1B2440;margin:40px;line-height:1.5;}'
        +'h1{font-size:24px;margin-bottom:4px;}'
        +'.contact{color:#5B6B8C;font-size:13px;margin-bottom:20px;}'
        +'h2{font-size:14px;text-transform:uppercase;letter-spacing:0.1em;color:'+ac+';border-bottom:2px solid '+ac+';padding-bottom:4px;margin-top:20px;margin-bottom:10px;}'
        +'.skill{display:inline-block;border:1px solid '+ac+';color:'+ac+';padding:2px 10px;border-radius:12px;font-size:12px;margin:2px;}'
        +'.item{margin-bottom:12px;}'
        +'.item-head{font-weight:600;font-size:14px;}'
        +'.item-meta{color:#5B6B8C;font-size:12px;}'
        +'.item-sub{color:#5B6B8C;font-size:13px;}'
        +'.body{text;font-size:13px;color:#2A3654;}'
        +'</style></head><body>';

      html+='<h1>'+name+'</h1><div class="contact">'+contactStr+'</div>';

      if(d.summary){
        html+='<h2>Summary</h2><p class="body">'+esc(d.summary)+'</p>';
      }
      if(d.experience&&d.experience.length){
        html+='<h2>Experience</h2>';
        d.experience.forEach(function(e){
          if(!e.role&&!e.company)return;
          html+='<div class="item"><div class="item-head">'+esc(e.role)+(e.company?' &mdash; '+esc(e.company):'')+'</div>';
          if(e.duration)html+='<div class="item-meta">'+esc(e.duration)+'</div>';
          if(e.description)html+='<p class="body">'+esc(e.description)+'</p>';
          html+='</div>';
        });
      }
      if(d.projects&&d.projects.length){
        html+='<h2>Projects</h2>';
        d.projects.forEach(function(p){
          if(!p.name)return;
          html+='<div class="item"><div class="item-head">'+esc(p.name)+'</div>';
          if(p.description)html+='<p class="body">'+esc(p.description)+'</p>';
          html+='</div>';
        });
      }
      if(d.skills&&d.skills.length){
        html+='<h2>Skills</h2><p>';
        d.skills.filter(Boolean).forEach(function(s){
          html+='<span class="skill">'+esc(s)+'</span> ';
        });
        html+='</p>';
      }
      if(d.education&&d.education.length){
        html+='<h2>Education</h2>';
        d.education.forEach(function(e){
          if(!e.degree&&!e.school)return;
          html+='<div class="item"><div class="item-head">'+esc(e.degree)+'</div>';
          if(e.school)html+='<div class="item-sub">'+esc(e.school)+'</div>';
          if(e.year)html+='<div class="item-meta">'+esc(e.year)+'</div>';
          html+='</div>';
        });
      }
      if(d.links&&d.links.length){
        html+='<h2>Links</h2><p class="body">'+d.links.filter(Boolean).map(function(l){return esc(l);}).join(' &bull; ')+'</p>';
      }

      html+='</body></html>';
      return html;
    }

    /* ══════════════════════════════════════════════════════
       AD OVERLAY MODAL
       ══════════════════════════════════════════════════════ */
    var adOverlay=document.getElementById('ad-overlay');
    var adSkipBtn=document.getElementById('ad-skip-btn');
    var adTimer=document.getElementById('ad-timer');
    var adVideoFrame=document.getElementById('ad-video-frame');
    var adStatus=document.getElementById('ad-status');
    var adCountdown=5;
    var adInterval=null;

    function showAdOverlay(){
      return new Promise(function(resolve){
        adOverlay.classList.remove('hidden');
        adOverlay.classList.add('flex');
        document.body.style.overflow='hidden';
        adCountdown=5;
        adTimer.textContent='Skip in '+adCountdown+'s';
        adSkipBtn.classList.add('hidden');
        adSkipBtn.disabled=true;
        adStatus.textContent='Loading ad...';

        // Simulate ad loading (replace with real ad tag later)
        setTimeout(function(){
          adStatus.textContent='Watching ad...';
          adInterval=setInterval(function(){
            adCountdown--;
            if(adCountdown<=0){
              clearInterval(adInterval);
              adTimer.textContent='Ad complete!';
              adSkipBtn.classList.remove('hidden');
              adSkipBtn.disabled=false;
              adSkipBtn.textContent='Download Now';
              adStatus.textContent='Your resume is ready!';
              resolve();
            } else {
              adTimer.textContent='Skip in '+adCountdown+'s';
            }
          },1000);
        },1000);

        adSkipBtn.onclick=function(){
          if(!adSkipBtn.disabled){
            clearInterval(adInterval);
            closeAdOverlay();
            resolve();
          }
        };
      });
    }

    function closeAdOverlay(){
      adOverlay.classList.add('hidden');
      adOverlay.classList.remove('flex');
      document.body.style.overflow='';
      if(adInterval)clearInterval(adInterval);
      adVideoFrame.src='';
    }

    /* ══════════════════════════════════════════════════════
       DOWNLOAD HANDLER (with ad + fallbacks)
       ══════════════════════════════════════════════════════ */
    function runDownload(skipAd){
      var btn=document.getElementById('start-download');
      var directBtn=document.getElementById('direct-download');
      btn.disabled=true;
      if(directBtn)directBtn.style.pointerEvents='none';

      if(selectedFormat==='docx'){
        var D=getDocxLib();
        if(!D){
          showProgress('').setError('Word library is still loading. Please wait a moment and try again, or choose PDF format.');
          btn.disabled=false;
          if(directBtn)directBtn.style.pointerEvents='';
          return;
        }
        var p=showProgress('Generating Word document…');
        p.setPercent(30);
        try{
          var tpl=allTemplates.find(function(x){return x.id===currentTplId;})||allTemplates[0];
          var doc=buildDocx(data,tpl);
          p.setPercent(60);
          document.getElementById('ad-progress').textContent='Packing Word file…';
          D.Packer.toBlob(doc).then(function(blob){
            p.setPercent(90);
            downloadBlob(blob,getFileName()+'.docx');
            p.setPercent(100);
            document.getElementById('ad-progress').textContent='Downloaded! Your Word file is ready.';
            setTimeout(function(){p.hide();},2000);
            btn.disabled=false;
            if(directBtn)directBtn.style.pointerEvents='';
          }).catch(function(err){
            console.warn('DOCX Packer failed:', err);
            document.getElementById('ad-progress').textContent='Word packing failed, trying alternative…';
            /* Fallback: download as rich HTML that Word can open */
            try{
              var tpl2=allTemplates.find(function(x){return x.id===currentTplId;})||allTemplates[0];
              var htmlContent=buildDocxHtmlFallback(data,tpl2);
              var blob2=new Blob([htmlContent],{type:'application/msword'});
              downloadBlob(blob2,getFileName()+'.doc');
              p.setPercent(100);
              document.getElementById('ad-progress').textContent='Downloaded as Word-compatible file.';
              setTimeout(function(){p.hide();},2000);
            }catch(e2){
              showProgress('').setError('Word generation failed: '+err.message+'. Try PDF format instead.');
            }
            btn.disabled=false;
            if(directBtn)directBtn.style.pointerEvents='';
          });
        }catch(err){
          console.error('DOCX build error:', err);
          showProgress('').setError('DOCX generation failed: '+err.message+'. Try PDF format instead.');
          btn.disabled=false;
          if(directBtn)directBtn.style.pointerEvents='';
        }
        return;
      }

      /* ── PDF with ad overlay + multi-fallback ── */
      var previewEl=document.getElementById('resume-preview');
      if(!previewEl||!previewEl.innerHTML||previewEl.innerHTML.length<10){
        showProgress('').setError('Resume content not loaded. Please go back to the builder and try again.');
        btn.disabled=false;
        if(directBtn)directBtn.style.pointerEvents='';
        return;
      }

      function attemptPDF(){
        var p=showProgress('Generating PDF…');
        p.setPercent(10);
        document.getElementById('ad-progress').textContent='Trying PDF method 1…';

        /* Attempt 1: html2canvas + jsPDF */
        pdfMethod_html2canvas().then(function(result){
          p.setPercent(60);
          document.getElementById('ad-progress').textContent='Saving PDF…';
          if(result.blob){
            downloadBlob(result.blob, getFileName()+'.pdf');
          } else if(result.dataUrl){
            downloadDataURL(result.dataUrl, getFileName()+'.pdf');
          }
          p.setPercent(100);
          document.getElementById('ad-progress').textContent='Downloaded! Your PDF is ready.';
          setTimeout(function(){p.hide();},2000);
          btn.disabled=false;
          if(directBtn)directBtn.style.pointerEvents='';
        }).catch(function(err1){
          console.warn('PDF Method 1 (html2canvas+jsPDF) failed:', err1.message||err1);
          p.setPercent(30);
          document.getElementById('ad-progress').textContent='Method 1 failed, trying print…';

          /* Attempt 2: Browser print */
          pdfMethod_browserPrint().then(function(result){
            if(result.usedPrint){
              p.setPercent(100);
              document.getElementById('ad-progress').textContent='Print dialog opened. Save as PDF from there.';
              setTimeout(function(){p.hide();},3000);
            }
            btn.disabled=false;
            if(directBtn)directBtn.style.pointerEvents='';
          }).catch(function(err2){
            console.warn('PDF Method 2 (browser print) failed:', err2.message||err2);
            p.setPercent(50);
            document.getElementById('ad-progress').textContent='Trying JPEG export…';

            /* Attempt 3: Canvas JPEG fallback */
            pdfMethod_canvasJpeg().then(function(result){
              p.setPercent(80);
              document.getElementById('ad-progress').textContent='Saving image…';
              downloadBlob(result.blob, result.filename||getFileName()+'_resume.jpg');
              p.setPercent(100);
              document.getElementById('ad-progress').textContent='Downloaded as high-quality image. You can convert to PDF at smallpdf.com.';
              setTimeout(function(){p.hide();},3000);
              btn.disabled=false;
              if(directBtn)directBtn.style.pointerEvents='';
            }).catch(function(err3){
              console.warn('PDF Method 3 (canvas JPEG) failed:', err3.message||err3);
              p.setPercent(70);
              document.getElementById('ad-progress').textContent='Final fallback…';

              /* Attempt 4: HTML file download */
              pdfMethod_htmlFallback().then(function(result){
                downloadBlob(result.blob, result.filename);
                p.setPercent(100);
                document.getElementById('ad-progress').textContent='Downloaded as HTML file. Open in browser and print to PDF (Ctrl+P → Save as PDF).';
                setTimeout(function(){p.hide();},4000);
                btn.disabled=false;
                if(directBtn)directBtn.style.pointerEvents='';
              }).catch(function(err4){
                console.error('All PDF methods failed:', err4);
                showProgress('').setError('All download methods failed. Please try: 1) Refresh page, 2) Use a different browser, 3) Check your internet connection.');
                btn.disabled=false;
                if(directBtn)directBtn.style.pointerEvents='';
              });
            });
          });
        });
      }

      if(skipAd){
        attemptPDF();
      } else {
        showAdOverlay().then(function(){
          attemptPDF();
        });
      }
    }

    document.getElementById('start-download').addEventListener('click',function(){runDownload(false);});
    document.getElementById('direct-download').addEventListener('click',function(){runDownload(true);});
  })();
  </script>
</BaseLayout>
