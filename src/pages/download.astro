        .rsm-doc { font-family: 'Inter','Segoe UI',system-ui,-apple-system,sans-serif; font-size: 16px; line-height: 1.6; color: #1B2440; width: ${w}px; height: ${h}px; overflow: hidden; background: #ffffff; box-sizing: border-box; }
        .rsm-single { padding: 38px 44px; display: flex; flex-direction: column; height: 100%; }
        .rsm-band { padding: 0; height: 100%; display: flex; flex-direction: column; }
        .rsm-band-top { padding: 28px 44px 20px; }
        .rsm-band-grid { display: grid; grid-template-columns: 1.4fr 1fr; gap: 28px; padding: 24px 44px 32px; flex: 1; }
        .rsm-sidebar-layout { display: flex; height: 100%; min-height: 0; }
        .rsm-sidebar { width: 34%; padding: 32px 24px; color: white; display: flex; flex-direction: column; align-items: flex-start; overflow-y: auto; box-sizing: border-box; }
        .rsm-main { width: 66%; padding: 30px 30px; display: flex; flex-direction: column; box-sizing: border-box; }
        .rsm-header { display: flex; align-items: center; gap: 16px; margin-bottom: 18px; }
        .rsm-photo { width: 66px; height: 66px; border-radius: 4px; object-fit: cover; flex-shrink: 0; }
        .rsm-photo-fallback { display: flex; align-items: center; justify-content: center; color: white; font-weight: 700; font-size: 24px; }
        .rsm-name { font-size: 30px; font-weight: 700; line-height: 1.2; letter-spacing: -0.02em; }
        .rsm-contact { font-size: 13px; color: #5B6B8C; margin-top: 4px; }
        .rsm-rule { border: none; border-top: 1.5px solid; margin: 16px 0 20px; }
        .rsm-section { margin-bottom: 18px; }
        .rsm-section-title { font-size: 13px; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 700; color: #5B6B8C; margin-bottom: 10px; padding-bottom: 6px; border-bottom: 2px solid #E2E8F0; }
        .rsm-body { font-size: 15px; color: #2A3654; line-height: 1.65; }
